{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPAO-T",
  "version": "0.1.0",
  "identifier": "app.gpao.t.local",
  "build": {
    "frontendDist": "../tauri-shell"
  },
  "app": {
    "windows": [
      {
        "title": "GPAO-T",
        "width": 1280,
        "height": 860,
        "minWidth": 390,
        "minHeight": 640,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'none'; connect-src 'self' http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
