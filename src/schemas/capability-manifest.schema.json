{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gpao-t3.local/schemas/capability-manifest.v1.json",
  "title": "GPAO-T3 Capability Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "manifestVersion", "id", "name", "version", "kind", "groups", "capabilities", "protocol", "inputSchema", "outputSchema", "streaming", "cancellation", "timeoutMs", "cost", "secretBoundary", "authority", "sideEffect", "isolation", "lifecycle", "provenance", "status"],
  "properties": {
    "schema": { "const": "gpao_t3.capability_manifest.v1" },
    "manifestVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["tool", "model", "channel", "mcp", "browser", "device", "runtime"] },
    "groups": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["runtime", "files", "web", "browser_ui", "messaging_channels", "sessions_agents", "automation", "gateway_devices", "memory_context", "media", "tool_search_plugins_mcp"] } },
    "capabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "protocol": { "type": "object", "additionalProperties": false, "required": ["major", "minor", "minCompatibleMinor"], "properties": { "major": { "type": "integer", "minimum": 1 }, "minor": { "type": "integer", "minimum": 0 }, "minCompatibleMinor": { "type": "integer", "minimum": 0 } } },
    "inputSchema": { "type": "object" }, "outputSchema": { "type": "object" },
    "streaming": { "type": "boolean" }, "cancellation": { "type": "boolean" }, "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 3600000 },
    "cost": { "type": "object" }, "secretBoundary": { "type": "string" },
    "authority": { "enum": ["read", "local_write", "external_send", "external_mutation", "destructive"] },
    "sideEffect": { "enum": ["none", "local", "external", "destructive"] },
    "isolation": { "type": "object" }, "lifecycle": { "type": "object" }, "provenance": { "type": "object" },
    "status": { "enum": ["not_configured", "ready", "degraded", "blocked", "disabled"] }
  }
}
