{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gpao-t3.local/schemas/response-document.v1.json",
  "title": "GPAO-T3 Response Document v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "id", "turnId", "sessionId", "blocks", "createdAt", "digest"],
  "properties": {
    "schema": { "const": "gpao_t3.response_document.v1" },
    "version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "turnId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "blocks": { "type": "array", "minItems": 1, "maxItems": 256, "items": { "$ref": "response-block.v1.schema.json" } },
    "createdAt": { "type": "number" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
